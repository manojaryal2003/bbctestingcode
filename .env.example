# =============================================================================
# BBC School Management System — Regression Test Credentials (EXAMPLE)
# =============================================================================
# Copy this file to .env and fill in the real values.
# This file uses placeholder values and is safe to commit to GitHub.
# NEVER put real credentials in this file.
# =============================================================================

# Live application base URL
BASE_URL=https://bbc.smartitsolutionnepal.com

# ── Head Admin credentials ───────────────────────────────────────────────────
ADMIN_USER_ID=admin_user_id_here
ADMIN_PASSWORD=admin_password_here

# ── Franchise Admin credentials ──────────────────────────────────────────────
FRANCHISE_USER_ID=franchise_user_id_here
FRANCHISE_PASSWORD=franchise_password_here

# ── Mentor credentials ───────────────────────────────────────────────────────
MENTOR_USER_ID=mentor_user_id_here
MENTOR_PASSWORD=mentor_password_here

# ── Student credentials ──────────────────────────────────────────────────────
STUDENT_USER_ID=student_user_id_here
STUDENT_PASSWORD=student_password_here

# ── Parent credentials ───────────────────────────────────────────────────────
PARENT_USER_ID=parent_user_id_here
PARENT_PASSWORD=parent_password_here

# ── Browser config ───────────────────────────────────────────────────────────
# Set to "true" to run headless (no visible browser window), "false" to watch
HEADLESS=false

# Implicit page-load / element-wait timeout in seconds
WAIT_TIMEOUT=10
